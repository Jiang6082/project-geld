ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Separate Alpaca paper accounts. These names correspond to the
# credential_profile values in configs/paper-swing-v4.toml and
# configs/paper-intraday.toml.
ALPACA_SWING_API_KEY=
ALPACA_SWING_SECRET_KEY=
ALPACA_INTRADAY_API_KEY=
ALPACA_INTRADAY_SECRET_KEY=

# Required by SEC EDGAR fair-access policy for fundamentals research.
# Example: ProjectGeld your-email@example.com
PROJECT_GELD_SEC_USER_AGENT=

# Required in addition to --submit before Project Geld sends paper orders.
PROJECT_GELD_CONFIRM_PAPER=YES
PROJECT_GELD_SWING_CONFIRM_PAPER=NO
PROJECT_GELD_INTRADAY_CONFIRM_PAPER=NO
